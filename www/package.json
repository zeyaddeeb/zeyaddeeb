{
  "name": "zeyaddeeb",
  "version": "0.1.20",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "docker compose up -d && turbo dev",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:push": "turbo run db:push --filter=@zeyaddeeb/db",
    "db:seed": "turbo run db:seed --filter=@zeyaddeeb/db",
    "lint": "biome lint",
    "format": "biome format --write",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "@tanstack/react-query": "^5.100.10",
    "@types/node": "25.8.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.3"
  }
}
